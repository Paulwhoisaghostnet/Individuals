# Public loopback port used by the host reverse proxy in production.
INDIVIDUALS_PORT=4174

# Shared-host resource ceilings. Tune after measuring a representative society;
# do not remove them on a host that also runs other projects.
INDIVIDUALS_RUNTIME_CPUS=1.50
INDIVIDUALS_RUNTIME_MEMORY_LIMIT=1g
INDIVIDUALS_RUNTIME_MEMORY_RESERVATION=256m
INDIVIDUALS_WEB_CPUS=0.25
INDIVIDUALS_WEB_MEMORY_LIMIT=128m
INDIVIDUALS_WEB_MEMORY_RESERVATION=32m

# Supplementary Linux group that may read deploy/secrets on the host.
INDIVIDUALS_SECRET_GID=991

# Local runtime settings. Compose overrides host and data directory inside its
# private container network.
INDIVIDUALS_API_HOST=127.0.0.1
INDIVIDUALS_API_PORT=4175
INDIVIDUALS_DATA_DIR=.data/individuals
# The authored manifests default to ten minutes. Lower this for accelerated local
# observation, but account for provider and exhibition budgets.
INDIVIDUALS_CYCLE_INTERVAL_MS=600000
# Hard end-to-end deadline, including admission and durable commit. A timed-out
# Individual stays fenced against overlapping cycles until its adapter settles,
# while shared capacity is released so its peers can continue.
INDIVIDUALS_CYCLE_TIMEOUT_MS=120000

# `npm run demo` uses an accelerated, separately namespaced runtime.
INDIVIDUALS_DEMO_CYCLE_INTERVAL_MS=5000
INDIVIDUALS_DEMO_DATA_DIR=.data/demo-individuals

# Exact browser origins permitted to send curator mutations. Add the production
# HTTPS origin before deployment; do not use a wildcard.
INDIVIDUALS_ALLOWED_ORIGINS=http://127.0.0.1:4174,http://localhost:4174

# Curator controls stay disabled until one of these is configured. Prefer the file
# form in production and use at least 32 random bytes.
# INDIVIDUALS_CURATOR_TOKEN=
# INDIVIDUALS_CURATOR_TOKEN_FILE=/run/secrets/curator-token

# Model-backed cognition is optional. Without a key, the causal procedural fallback
# keeps the society running. Prefer LLM_API_KEY_FILE in production.
# LLM_API_BASE=https://provider.example/v1
# LLM_MODEL=provider-model-id
# LLM_API_KEY=
# LLM_API_KEY_FILE=/run/secrets/llm-api-key
